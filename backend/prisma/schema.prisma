// Prisma schema for Auction Management System
// Run `npx prisma generate` after editing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizer {
  id    Int    @id @default(autoincrement())
  name  String
  email String?
  rooms AuctionRoom[]
}

model AuctionRoom {
  id           Int      @id @default(autoincrement())
  roomName     String
  organizerId  Int
  organizer    Organizer @relation(fields: [organizerId], references: [id])
  status       String   @default("waiting") // live, ended, waiting
  items        Item[]
  participants Participant[]
}

model Item {
  id            Int      @id @default(autoincrement())
  name          String
  price         Float
  currentBid    Float?
  firstBid      Float?
  winnerId      Int?
  winner        Participant? @relation("Item_winner", fields: [winnerId], references: [id])
  status        String   @default("unsold") // unsold, progress, sold
  auctionRoomId Int
  auctionRoom   AuctionRoom @relation(fields: [auctionRoomId], references: [id])
  bids          Bid[]
}

model Participant {
  id             Int      @id @default(autoincrement())
  name           String
  purseAmount    Float
  remainingPurse Float
  roomId         Int
  auctionRoom    AuctionRoom @relation(fields: [roomId], references: [id])
  bids           Bid[]
  winningItems   Item[]   @relation("Item_winner")
}

model Bid {
  id           Int      @id @default(autoincrement())
  amount       Float
  participantId Int
  participant  Participant @relation(fields: [participantId], references: [id])
  itemId       Int
  item         Item     @relation(fields: [itemId], references: [id])
  timestamp    DateTime @default(now())
}
